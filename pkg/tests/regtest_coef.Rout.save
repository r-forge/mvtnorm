> 
> library("mvtnorm")
> 
> options(digits = 4)
> 
> J <- 5
> 
> lxd <- ltMatrices(runif(J * (J + 1) / 2) + 1, diag = TRUE, names = LETTERS[seq_len(J)])
> m <- matrix(1:J, ncol = 1)
> d <- Mult(lxd, m)
> 
> d0 <- mvnorm(invchol = lxd)
> Y <- as.data.frame(t(simulate(d0, nsim = 1e6, seed = 29)))
> mlm <- lm(D ~ 0 + A + B + C, data = Y)
> (cf <- coef(d0, which = "D"))
     A      B      C 
-1.214 -1.105 -1.051 
attr(,"sigma")
     D 
0.6183 
> coef(mlm)
     A      B      C 
-1.213 -1.104 -1.050 
> summary(mlm)$sigma
[1] 0.6174
> md <- margDist(d0, which = 1:4)
> cd <- condDist(md, which_given = 1:3, given = diag(3))
> class(cd$scale)
[1] "invchol"    "ltMatrices" "matrix"     "array"     
> coef(cd)
    [,1]   [,2]   [,3]
D -1.214 -1.105 -1.051
attr(,"sigma")
[1] 0.6183
> 
